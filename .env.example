# Google Vision API (OCR)
GOOGLE_VISION_API_KEY=

# Aligo 알림톡 (api/alimtalk.js)
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_KEY=
ALIGO_SENDER_TEL=
# 'sms' 면 알림톡 실패 시 SMS 자동 대체 (비용 발생)
ALIGO_FAILOVER=
# 'true' 면 실제 발송 X — 콘솔 로그만 (개발/테스트)
ALIGO_DRY_RUN=
ALIGO_ADMIN_KEY=

# Solapi SMS
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_FROM=
SMS_API_ADMIN_KEY=

# Vercel Serverless Functions (api/*.js)
# Vercel 대시보드 → Environment Variables 에 등록
ANTHROPIC_API_KEY=
DRIVE_API_KEY=
