{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".validate": "(!data.exists() && newData.val() !== 'admin') || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },

    "partners": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["partner_code", "partner_type"]
    },

    "policies": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'provider')",
      ".indexOn": ["policy_code", "provider_company_code"]
    },

    "terms": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "products": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["car_number", "product_code", "provider_company_code", "status", "vehicle_status"]
    },

    "product_code_aliases": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["product_uid", "agent_uid", "provider_uid", "provider_company_code", "last_message_at"]
    },

    "messages": {
      "$room_id": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$message_id": {
          "sender_uid": { ".validate": "newData.val() === auth.uid" }
        }
      }
    },

    "contracts": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'agent_uid' && query.equalTo === auth.uid) || (query.orderByChild === 'provider_company_code' && query.equalTo === root.child('users').child(auth.uid).child('company_code').val()) || (query.orderByChild === 'agent_channel_code' && query.equalTo === root.child('users').child(auth.uid).child('agent_channel_code').val()))",
      ".write": "auth != null",
      "$id": { ".read": "auth != null" },
      ".indexOn": ["product_uid", "partner_code", "contract_status", "agent_uid", "provider_company_code", "agent_channel_code", "created_at"]
    },

    "settlements": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'agent_uid' && query.equalTo === auth.uid) || (query.orderByChild === 'provider_company_code' && query.equalTo === root.child('users').child(auth.uid).child('company_code').val()) || (query.orderByChild === 'agent_channel_code' && query.equalTo === root.child('users').child(auth.uid).child('agent_channel_code').val()))",
      ".write": "auth != null",
      "$id": { ".read": "auth != null" },
      ".indexOn": ["contract_code", "settlement_status", "provider_company_code", "agent_uid", "agent_channel_code"]
    },

    "admin_settlements": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["settle_month", "settle_status", "contract_code"]
    },

    "customers": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'created_by' && query.equalTo === auth.uid))",
      ".write": "auth != null",
      "$id": { ".read": "auth != null" },
      ".indexOn": ["phone", "name", "created_at", "created_by"]
    },

    "inquiries": {
      ".read": "auth != null",
      "$id": {
        ".write": true,
        ".validate": "newData.hasChildren(['visitor_name', 'visitor_phone', 'created_at']) && newData.child('visitor_name').isString() && newData.child('visitor_phone').isString() && newData.child('visitor_name').val().length > 0 && newData.child('visitor_phone').val().length >= 10 && newData.child('visitor_phone').val().length <= 13",
        "created_at": { ".validate": "newData.isNumber() && newData.val() <= now + 5000" },
        "visitor_name": { ".validate": "newData.val().length <= 30" },
        "message": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)" }
      },
      ".indexOn": ["product_uid", "agent_code", "status", "created_at"]
    },

    "code_sequences": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "input_codes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["group_code"]
    },

    "vehicle_master": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "car_models": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["maker", "model", "code"]
    },

    "color_master": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "home_notices": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "proposals": {
      ".read": true,
      ".write": "auth != null"
    },

    "proposal_views": {
      "$id": {
        ".read": "auth != null",
        ".write": true
      }
    },

    "contract_sign": {
      "$token": {
        ".read": true,
        ".write": "root.child('contract_sign').child($token).exists() || auth != null"
      }
    },

    "fcm_tokens": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "sms_cooldown": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    },

    "counters": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "audit_logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["ts", "actor_uid", "collection"],
      "$auto": {
        ".write": "auth != null && newData.child('actor_uid').val() === auth.uid",
        ".validate": "newData.hasChildren(['action', 'collection', 'actor_uid', 'ts'])"
      }
    },

    "backup": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "api_keys": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
